---
interface Props {
  tags: {
    name: string
    slug: string
    count?: number
  }[]
}

const { tags } = Astro.props
---

{
  tags.length === 0 ? (
    <div class="text-center text-sm">作者没有准备标签😦</div>
  ) : (
    <div class="flex flex-wrap gap-2.5">
      {tags.map((tag) => (
        <a class="relative block group" href={`/tags/${tag.slug}`}>
          <div class="px-2.5 py-2 inset-0 rounded-lg bg-accent/10 text-sm flex items-baseline gap-1 select-none hover:transition hover:bg-accent/20 hover:scale-105">
            <span>{tag.name}</span>
            {tag.count && <span class="text-xs">({tag.count})</span>}
          </div>
        </a>
      ))}
    </div>
  )
}
