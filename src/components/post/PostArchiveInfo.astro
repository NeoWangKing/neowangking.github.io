---
import { slugify } from '@/utils/content'

interface Props {
  tags: string[]
  category: string[]
  class?: string
}

const { tags, category, class: className } = Astro.props
---

<div class="flex flex-wrap gap-2 text-sm text-secondary" class:list={[className]}>
  {
    <div>
      <i class="iconfont icon-menu" />
      <a
        class="m-0.5 py-1 px-2 bg-accent/10 rounded-full hover:text-accent hover:bg-accent/20 transition duration-300"
        href={`/categories/${slugify(category[0])}`}
      >
        {category[0]}
      </a> / <a
        class="m-0.5 py-1 px-2 bg-accent/10 rounded-full hover:text-accent hover:bg-accent/20 transition duration-300"
        href={`/categories/${slugify(category.join('/'))}`}
      >
        {category[1]}
      </a>
    </div>
  }
  {
    tags.length > 0 && (
      <div>
        <i class="iconfont icon-hashtag" />
        {tags.map((tag) => (
          <>
            <a
              class="m-0.5 py-1 px-2 bg-accent/10 rounded-full hover:text-accent hover:bg-accent/20 transition duration-300"
              href={`/tags/${slugify(tag)}`}
            >
              {tag}
            </a>
          </>
        ))}
      </div>
    )
  }
</div>
